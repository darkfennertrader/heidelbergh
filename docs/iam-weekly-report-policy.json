{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "SendWeeklyReportEmailViaSES",
            "Effect": "Allow",
            "Action": [
                "ses:SendEmail",
                "ses:SendRawEmail"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "ses:FromAddress": "darkfenner69@gmail.com"
                }
            }
        },
        {
            "Sid": "WeeklyReportS3UploadAndPresign",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::appway-bridge-prod",
                "arn:aws:s3:::appway-bridge-prod/weekly-reports/*"
            ]
        }
    ]
}